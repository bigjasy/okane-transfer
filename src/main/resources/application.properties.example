# ── Database ──────────────────────────────────────────
# Exemple local : jdbc:postgresql://localhost:5432/okane_transfer
db.url=
db.username=
db.password=
db.driver=org.postgresql.Driver

# ── Hibernate ─────────────────────────────────────────
hibernate.ddl-auto=none
hibernate.dialect=org.hibernate.dialect.PostgreSQLDialect
hibernate.show-sql=false
hibernate.format-sql=true

# ── Secrets ───────────────────────────────────────────
# AES-256 key for encrypting sensitive DB fields (32 bytes, Base64 or raw)
# Local dev example only, do not use in production:
# aes.key=12345678901234567890123456789012
# You can also set OKANE_AES_KEY in the runtime environment.
aes.key=
# JWT signing secret (min 32 bytes); empty = auto-generated on each restart
jwt.secret=
# Google Gemini API key for chatbot (get one at https://aistudio.google.com/apikey)
gemini.api.key=

# Production frontend build (served from same host as Tomcat):
#   npm run build -- --configuration=production
# API base URL is resolved from window.location.origin + /okane_transfer_war/api/v1
# Add your production domain to cors.allowed-origins below.

cors.allowed-origins=http://localhost:4200,http://localhost:4300,http://127.0.0.1:4200,http://127.0.0.1:4300
kyc.upload-dir=
aml.threshold=10000
exchange-rate.external.provider=OkaneFX-Simulated

# ── Notifications (real delivery) ─────────────────────
# Set enabled=true and fill credentials before deployment.
notification.email.enabled=false
notification.sms.enabled=false
# Local dev only: return OTP in API response when mail/SMS is not configured
notification.dev.expose-otp=true

# SMTP (Gmail example: use an App Password, not your account password)
mail.host=smtp.gmail.com
mail.port=587
mail.username=
mail.password=
mail.from=OkaneTransfer <noreply@okane.ma>
mail.starttls=true

# Twilio SMS (https://www.twilio.com)
twilio.account-sid=
twilio.auth-token=
twilio.from-number=

# Dev-only secrets (never commit real values):
# aes.key=OkaneTransferDevAesKey1234567890
# jwt.secret=OkaneTransferDevJwtSecretKey1234567890
